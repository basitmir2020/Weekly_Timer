<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:WeeklyTimetable.Controls"
             x:Class="WeeklyTimetable.Controls.RingProgressControl">
             
    <GraphicsView x:Name="RingGraphicsView" 
                  HeightRequest="{Binding Size, Source={RelativeSource AncestorType={x:Type local:RingProgressControl}}}"
                  WidthRequest="{Binding Size, Source={RelativeSource AncestorType={x:Type local:RingProgressControl}}}" 
                  BackgroundColor="Transparent" />
</ContentView>
