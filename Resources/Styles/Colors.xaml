<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Global App Colors (Dark) -->
    <Color x:Key="BgPageDark">#07090f</Color>
    <Color x:Key="BgHeaderDark">#0a0c14</Color>
    <Color x:Key="BgNavDark">#08090f</Color>
    <Color x:Key="BgCardDark">#09090f</Color>
    
    <Color x:Key="BorderSubtleDark">#0d1117</Color>
    <Color x:Key="BorderLightDark">#0f172a</Color>
    <Color x:Key="BorderVisibleDark">#1e293b</Color>

    <Color x:Key="TextBodyDark">#cbd5e1</Color>
    <Color x:Key="TextHeadingDark">#f1f5f9</Color>
    <Color x:Key="TextMutedDark">#334155</Color>
    <Color x:Key="TextVeryMutedDark">#1e293b</Color>

    <!-- Global App Colors (Light) -->
    <Color x:Key="BgPageLight">#f8fafc</Color>
    <Color x:Key="BgHeaderLight">#f1f5f9</Color>
    <Color x:Key="BgNavLight">#ffffff</Color>
    <Color x:Key="BgCardLight">#ffffff</Color>
    
    <Color x:Key="BorderSubtleLight">#f1f5f9</Color>
    <Color x:Key="BorderLightLight">#e2e8f0</Color>
    <Color x:Key="BorderVisibleLight">#cbd5e1</Color>

    <Color x:Key="TextBodyLight">#334155</Color>
    <Color x:Key="TextHeadingLight">#0f172a</Color>
    <Color x:Key="TextMutedLight">#64748b</Color>
    <Color x:Key="TextVeryMutedLight">#94a3b8</Color>
    
    <!-- Constant Colors -->
    <Color x:Key="AccentPurple">#818cf8</Color>
    <Color x:Key="SuccessGreen">#22c55e</Color>

    <!-- Themed Aliases (Allows existing XAML to remain unchanged) -->
    <OnAppTheme x:Key="BgPage" x:TypeArguments="Color" Light="{StaticResource BgPageLight}" Dark="{StaticResource BgPageDark}" />
    <OnAppTheme x:Key="BgHeader" x:TypeArguments="Color" Light="{StaticResource BgHeaderLight}" Dark="{StaticResource BgHeaderDark}" />
    <OnAppTheme x:Key="BgNav" x:TypeArguments="Color" Light="{StaticResource BgNavLight}" Dark="{StaticResource BgNavDark}" />
    <OnAppTheme x:Key="BgCardDim" x:TypeArguments="Color" Light="{StaticResource BgCardLight}" Dark="{StaticResource BgCardDark}" />
    
    <OnAppTheme x:Key="BorderSubtle" x:TypeArguments="Color" Light="{StaticResource BorderSubtleLight}" Dark="{StaticResource BorderSubtleDark}" />
    <OnAppTheme x:Key="BorderLight" x:TypeArguments="Color" Light="{StaticResource BorderLightLight}" Dark="{StaticResource BorderLightDark}" />
    <OnAppTheme x:Key="BorderVisible" x:TypeArguments="Color" Light="{StaticResource BorderVisibleLight}" Dark="{StaticResource BorderVisibleDark}" />

    <OnAppTheme x:Key="TextBody" x:TypeArguments="Color" Light="{StaticResource TextBodyLight}" Dark="{StaticResource TextBodyDark}" />
    <OnAppTheme x:Key="TextHeading" x:TypeArguments="Color" Light="{StaticResource TextHeadingLight}" Dark="{StaticResource TextHeadingDark}" />
    <OnAppTheme x:Key="TextMuted" x:TypeArguments="Color" Light="{StaticResource TextMutedLight}" Dark="{StaticResource TextMutedDark}" />
    <OnAppTheme x:Key="TextVeryMuted" x:TypeArguments="Color" Light="{StaticResource TextVeryMutedLight}" Dark="{StaticResource TextVeryMutedDark}" />

    <!-- Category Colors -->
    <Color x:Key="CatSleep">#3b82f6</Color>
    <Color x:Key="CatWork">#22c55e</Color>
    <Color x:Key="CatStudy">#8b5cf6</Color>
    <Color x:Key="CatExercise">#f97316</Color>
    <Color x:Key="CatMeal">#f59e0b</Color>
    <Color x:Key="CatBreak">#14b8a6</Color>
    <Color x:Key="CatRelax">#ec4899</Color>
    <Color x:Key="CatRoutine">#64748b</Color>

</ResourceDictionary>