<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Typographic Styles -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextBody}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="H1" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextHeading}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="28" />
    </Style>

    <Style x:Key="H2" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextHeading}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="20" />
    </Style>
    
    <Style x:Key="MonoLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" /> <!-- Placeholder for DMMono -->
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Layout & Component Styles -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BgCardDim}" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0, 4" />
    </Style>
    
    <Style x:Key="PillStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{StaticResource BorderVisible}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Padding" Value="12, 6" />
    </Style>

</ResourceDictionary>
