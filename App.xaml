<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:WeeklyTimetable"
             x:Class="WeeklyTimetable.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Dynamic Font Scaling Resources -->
            <x:Double x:Key="BaseFontSize">14</x:Double>
            <x:Double x:Key="SmallFontSize">11</x:Double>
            <x:Double x:Key="HeaderFontSize">20</x:Double>
            <x:Double x:Key="HeroFontSize">28</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
