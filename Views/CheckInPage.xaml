<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:WeeklyTimetable.Converters"
             xmlns:controls="clr-namespace:WeeklyTimetable.Controls"
             x:Class="WeeklyTimetable.Views.CheckInPage"
             BackgroundColor="{StaticResource BgPage}"
             Title="Daily Check-In">

    <ContentPage.Resources>
        <converters:EnergyToColorConverter x:Key="EnergyToColor" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="24">
            <Label Text="How are you feeling today?" Style="{StaticResource H2}" />

            <!-- Morning Energy -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="☀️  Morning Energy" FontAttributes="Bold" />
                    <controls:EnergySliderControl Value="{Binding MorningEnergy}" />
                </VerticalStackLayout>
            </Border>

            <!-- Evening Mood -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="🌙  Evening Mood" FontAttributes="Bold" />
                    <controls:EnergySliderControl Value="{Binding EveningMood}" />
                </VerticalStackLayout>
            </Border>

            <!-- Notes -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📓  Notes (Optional)" FontAttributes="Bold" />
                    <Editor Placeholder="Any reflections from today..." PlaceholderColor="{StaticResource TextMuted}"
                            Text="{Binding Notes}" TextColor="{StaticResource TextBody}"
                            BackgroundColor="Transparent" HeightRequest="100" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Save Check-In" Command="{Binding SaveCheckInCommand}"
                    BackgroundColor="{StaticResource AccentPurple}" TextColor="{StaticResource BgPage}"
                    FontAttributes="Bold" CornerRadius="12" HeightRequest="52" />

            <Label Text="✅  Saved for today!" IsVisible="{Binding IsSaved}"
                   TextColor="{StaticResource SuccessGreen}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
