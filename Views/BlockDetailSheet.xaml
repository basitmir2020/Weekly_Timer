<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:WeeklyTimetable.Converters"
             x:Class="WeeklyTimetable.Views.BlockDetailSheet"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
             Title="Block Details">

    <ContentPage.Resources>
        <converters:Time24To12HrConverter x:Key="Time24To12Hr" />
        <converters:DurationToStringConverter x:Key="DurationToString" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24">
            <!-- Header -->
            <Label Text="{Binding Block.Icon}" FontSize="48" HorizontalOptions="Center" />
            <Label Text="{Binding Block.Label}" Style="{StaticResource H2}" HorizontalOptions="Center" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Label Text="{Binding Block.Time, Converter={StaticResource Time24To12Hr}}" TextColor="{StaticResource AccentPurple}" FontAttributes="Bold" />
                <Label Text="·" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Label Text="{Binding Block.DurationMinutes, Converter={StaticResource DurationToString}}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Label Text="·" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Label Text="{Binding Block.Category}" Style="{StaticResource MonoLabel}" />
            </HorizontalStackLayout>

            <!-- Notes -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📝  Study Notes" FontAttributes="Bold" />
                    <Editor Placeholder="Add notes, key takeaways, or next steps..."
                            PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                            Text="{Binding Notes}" TextColor="{AppThemeBinding Light={StaticResource TextBodyLight}, Dark={StaticResource TextBodyDark}}"
                            BackgroundColor="Transparent" HeightRequest="140" AutoSize="TextChanges" />
                </VerticalStackLayout>
            </Border>

            <!-- Save -->
            <Button Text="Save Notes" Command="{Binding SaveNotesCommand}"
                    BackgroundColor="{StaticResource AccentPurple}" TextColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
                    FontAttributes="Bold" CornerRadius="12" HeightRequest="48" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
