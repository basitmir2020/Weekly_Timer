<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WeeklyTimetable.ViewModels"
             xmlns:models="clr-namespace:WeeklyTimetable.Models"
             xmlns:local="clr-namespace:WeeklyTimetable.Views"
             x:Class="WeeklyTimetable.Views.DaySchedulePage"
             x:DataType="vm:MainViewModel">
             
    <VerticalStackLayout Spacing="10" Padding="20">
        <Label Text="Day Schedule View" FontAttributes="Bold" FontSize="18" />
        <CollectionView ItemsSource="{Binding FilteredBlocks}" ItemSizingStrategy="MeasureFirstItem" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ScheduleBlock">
                    <Label Text="{Binding Label}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
