<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:WeeklyTimetable.Controls"
             xmlns:vm="clr-namespace:WeeklyTimetable.ViewModels"
             xmlns:converters="clr-namespace:WeeklyTimetable.Converters"
             x:Class="WeeklyTimetable.Views.AnalyticsDashboardPage"
             x:DataType="vm:AnalyticsViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
             Title="Analytics">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:PercentToProgressConverter x:Key="PercentToProgressConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- Weekly Scorecard -->
            <Label Text="🏆 Weekly Scorecard" Style="{StaticResource H2}" />
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Execution" Style="{StaticResource MonoLabel}" />
                        <Label Text="{Binding ExecutionScore, StringFormat='{0:F0}%'}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource AccentPurple}" />
                        <ProgressBar Progress="{Binding ExecutionScore, Converter={StaticResource PercentToProgressConverter}}" ProgressColor="{StaticResource AccentPurple}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Goals" Style="{StaticResource MonoLabel}" />
                        <Label Text="{Binding GoalCompletionPercent, StringFormat='{0:F0}%'}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource SuccessGreen}" />
                        <ProgressBar Progress="{Binding GoalCompletionPercent, Converter={StaticResource PercentToProgressConverter}}" ProgressColor="{StaticResource SuccessGreen}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Consistency" Style="{StaticResource MonoLabel}" />
                        <Label Text="{Binding ConsistencyScore, StringFormat='{0:F0}%'}" FontSize="24" FontAttributes="Bold" TextColor="#facc15" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Planned vs Done" Style="{StaticResource MonoLabel}" />
                        <Label Text="{Binding TotalCompletedBlocks, StringFormat='{0}/{1}'}" FontSize="20" FontAttributes="Bold" />
                        <Label Text="blocks" FontSize="10" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Weekly Goals Snapshot -->
            <Border IsVisible="{Binding HasWeeklyGoals}" Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="🎯 Weekly Goals" TextColor="{AppThemeBinding Light={StaticResource TextHeadingLight}, Dark={StaticResource TextHeadingDark}}" FontAttributes="Bold" FontSize="16" />
                        <Label Grid.Column="1" Text="{Binding GoalsProgressText}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" VerticalOptions="Center" />
                    </Grid>

                    <Label Text="{Binding GoalCountdownText}" TextColor="#facc15" FontSize="12" />

                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding WeeklyGoalItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:GoalTrackerItem">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="{Binding StatusText}" TextColor="{Binding StatusColor}" FontSize="14" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextHeadingLight}, Dark={StaticResource TextHeadingDark}}" />
                                        <Label Text="{Binding GoalText}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" LineBreakMode="TailTruncation" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Streak Summary Cards -->
            <Label Text="📊 Progress Overview" Style="{StaticResource H2}" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="🔥" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="{Binding CurrentStreak}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource AccentPurple}" HorizontalOptions="Center" />
                        <Label Text="Current" Style="{StaticResource MonoLabel}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="🏆" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="{Binding LongestStreak}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource SuccessGreen}" HorizontalOptions="Center" />
                        <Label Text="Best" Style="{StaticResource MonoLabel}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="📅" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="{Binding TotalCompleteDays}" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextHeadingLight}, Dark={StaticResource TextHeadingDark}}" HorizontalOptions="Center" />
                        <Label Text="Complete" Style="{StaticResource MonoLabel}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Heatmap -->
            <Label Text="📅 12-Week Heatmap" Style="{StaticResource H2}" Margin="0,8,0,0" />
            <Border Style="{StaticResource CardStyle}">
                <controls:HeatmapGridControl HeatmapCells="{Binding HeatmapCells}" />
            </Border>

            <!-- Category Breakdown -->
            <Label Text="📊 Category Breakdown" Style="{StaticResource H2}" Margin="0,8,0,0" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding CategoryBreakdown}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:CategoryBreakdown">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Category}" FontAttributes="Bold" FontSize="12" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Label}" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                             Progress="{Binding Minutes, Converter={StaticResource PercentToProgressConverter}, ConverterParameter=1000}" 
                                             ProgressColor="{Binding Color}" ScaleY="0.5" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>

            <!-- Smart Insights Section -->
            <Label Text="💡 Smart Insights" Style="{StaticResource H2}" Margin="0,8,0,0" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Top Performed" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                            <Label Text="{Binding TopCategory}" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource AccentPurple}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Lowest Focus" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                            <Label Text="{Binding LowCategory}" FontAttributes="Bold" FontSize="14" TextColor="#f472b6" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderVisibleLight}, Dark={StaticResource BorderVisibleDark}}" />

                    <VerticalStackLayout Spacing="12" BindableLayout.ItemsSource="{Binding WeeklyInsights}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:InsightItem">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="{Binding Icon}" FontSize="20" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="12" />
                                        <Label Text="{Binding Description}" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Recommendations -->
            <Label Text="🚀 Recommendations" Style="{StaticResource H2}" Margin="0,8,0,0" />
            <Border Style="{StaticResource CardStyle}" BackgroundColor="{AppThemeBinding Light=#f0f9ff, Dark=#0c4a6e}" BorderColor="#0ea5e9">
                <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Recommendations}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnDefinitions="Auto, *">
                                <Label Text="•" TextColor="#0ea5e9" FontAttributes="Bold" Margin="0,0,8,0" />
                                <Label Grid.Column="1" Text="{Binding .}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextBodyLight}, Dark={StaticResource TextBodyDark}}" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>

            <!-- Reload -->
            <Button Text="Refresh Data" Command="{Binding LoadCommand}"
                    Margin="0,16,0,16"
                    BackgroundColor="Transparent" TextColor="{StaticResource AccentPurple}"
                    BorderColor="{AppThemeBinding Light={StaticResource BorderVisibleLight}, Dark={StaticResource BorderVisibleDark}}" BorderWidth="1" CornerRadius="8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
