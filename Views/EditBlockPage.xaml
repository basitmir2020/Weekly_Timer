<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WeeklyTimetable.ViewModels"
             x:Class="WeeklyTimetable.Views.EditBlockPage"
             x:DataType="vm:EditBlockViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
             Title="{Binding IsEditing, StringFormat='{0}'}" >

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <Label Text="{Binding IsEditing, StringFormat='Editing: {0}'}"
                   Style="{StaticResource H2}" />

            <!-- Time -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="⏰  Time" VerticalOptions="Center" WidthRequest="100" />
                    <Picker Grid.Column="1"
                           ItemsSource="{Binding AvailableTimes}"
                           SelectedItem="{Binding SelectedTimeOption}"
                           ItemDisplayBinding="{Binding DisplayTime}"
                           TextColor="{StaticResource AccentPurple}" />
                </Grid>
            </Border>

            <!-- Label -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="📝  Label" VerticalOptions="Center" WidthRequest="100" />
                    <Entry Grid.Column="1"
                           Text="{Binding Label}"
                           Placeholder="e.g. DSA Practice"
                           TextColor="{AppThemeBinding Light={StaticResource TextBodyLight}, Dark={StaticResource TextBodyDark}}"
                           BackgroundColor="Transparent" />
                </Grid>
            </Border>

            <!-- Icon -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="🎨  Icon" VerticalOptions="Center" WidthRequest="100" />
                    <Entry Grid.Column="1"
                           Text="{Binding Icon}"
                           Placeholder="Emoji e.g. 🧠"
                           TextColor="{AppThemeBinding Light={StaticResource TextBodyLight}, Dark={StaticResource TextBodyDark}}"
                           BackgroundColor="Transparent" />
                </Grid>
            </Border>

            <!-- Category -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="🏷️  Category" VerticalOptions="Center" WidthRequest="100" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding Category}"
                            TextColor="{StaticResource AccentPurple}" />
                </Grid>
            </Border>

            <!-- Duration -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding DurationMinutes, StringFormat='⏱️  Duration: {0} min'}" />
                    <Slider Minimum="5" Maximum="240" Value="{Binding DurationMinutes}"
                            ThumbColor="{StaticResource AccentPurple}"
                            MinimumTrackColor="{StaticResource AccentPurple}" />
                </VerticalStackLayout>
            </Border>

            <!-- Notes -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📓  Notes (Optional)" FontAttributes="Bold" />
                    <Editor Placeholder="Any reflections from today..." PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                            Text="{Binding Notes}" TextColor="{AppThemeBinding Light={StaticResource TextBodyLight}, Dark={StaticResource TextBodyDark}}"
                            BackgroundColor="Transparent" HeightRequest="100" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Save Block" Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource AccentPurple}"
                    TextColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
                    FontAttributes="Bold" CornerRadius="12" HeightRequest="52" />

            <!-- Delete (only when editing) -->
            <Button Text="Delete Block" Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditing}"
                    BackgroundColor="Transparent"
                    TextColor="#ef4444"
                    BorderColor="#ef4444" BorderWidth="1"
                    CornerRadius="12" HeightRequest="48" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
