<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WeeklyTimetable.ViewModels"
             xmlns:converters="clr-namespace:WeeklyTimetable.Converters"
             xmlns:models="clr-namespace:WeeklyTimetable.Models"
             x:Class="WeeklyTimetable.Views.GoalsPage"
             x:DataType="vm:GoalsViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
             Title="Weekly Goals">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:EnumToColorConverter x:Key="EnumToColorConverter" />
            <converters:GoalStatusToStringConverter x:Key="StatusToStringConverter" />
            <converters:BoolToStrikethroughConverter x:Key="StrikethroughConverter" />
            <converters:PercentToProgressConverter x:Key="PercentToProgressConverter" />
            <converters:EnumToValuesConverter x:Key="EnumToValuesConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Padding="16">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <Label Text="🎯 Weekly Planning" Style="{StaticResource H2}" />
            <Label Text="{Binding WeekDisplay}" Style="{StaticResource MonoLabel}" />
            <Label Text="Set priorities, track habits, and reflect on progress." 
                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" 
                   FontSize="13" />
        </VerticalStackLayout>

        <!-- Goals List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Goals}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:WeeklyGoalItemViewModel">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                            <!-- Title & Status -->
                            <Entry Grid.Row="0" Grid.Column="0" Text="{Binding Title}" 
                                   FontAttributes="Bold" FontSize="16" Placeholder="Goal Title..."
                                   TextColor="{AppThemeBinding Light={StaticResource TextHeadingLight}, Dark={StaticResource TextHeadingDark}}" />

                            <Border Grid.Row="0" Grid.Column="1" Padding="8,2" CornerRadius="12"
                                    BackgroundColor="{Binding Status, Converter={StaticResource EnumToColorConverter}}"
                                    HorizontalOptions="End" VerticalOptions="Start">
                                <Label Text="{Binding Status, Converter={StaticResource StatusToStringConverter}}" 
                                       TextColor="White" FontSize="10" FontAttributes="Bold" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleStatusCommand}" />
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Category & Priority -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="12" Margin="0,4">
                                <BoxView WidthRequest="4" HeightRequest="16" 
                                         Color="{Binding Priority, Converter={StaticResource EnumToColorConverter}}" 
                                         VerticalOptions="Center" />
                                <Picker Title="Category" 
                                        ItemsSource="{Binding BindingContext.Categories, Source={RelativeSource AncestorType={x:Type vm:GoalsViewModel}}}"
                                        SelectedItem="{Binding Category}"
                                        FontSize="12" HeightRequest="40" WidthRequest="110" />
                                <Picker Title="Priority"
                                        ItemsSource="{Binding Source={x:Null}, Converter={StaticResource EnumToValuesConverter}, ConverterParameter={x:Type models:GoalPriority}}"
                                        SelectedItem="{Binding Priority}"
                                        FontSize="12" HeightRequest="40" WidthRequest="110" />
                            </HorizontalStackLayout>

                            <!-- Description -->
                            <Editor Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                    Text="{Binding Description}" FontSize="13" Margin="0,4,0,8"
                                    Placeholder="Goal description..."
                                    AutoSize="TextChanges"
                                    TextColor="{AppThemeBinding Light={StaticResource TextBodyLight}, Dark={StaticResource TextBodyDark}}" />

                            <!-- Subtasks -->
                            <CollectionView Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                            ItemsSource="{Binding Subtasks}" 
                                            Margin="0,0,0,8">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GoalSubtaskViewModel">
                                        <Grid ColumnDefinitions="Auto, *" Padding="0,2">
                                            <CheckBox IsChecked="{Binding IsCompleted}" 
                                                      Command="{Binding ToggleCommand}"
                                                      Color="{StaticResource AccentPurple}"
                                                      VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding Title}" 
                                                   VerticalOptions="Center" FontSize="13"
                                                   TextDecorations="{Binding IsCompleted, Converter={StaticResource StrikethroughConverter}}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Button Grid.Row="3" Grid.Column="1" Text="+" Command="{Binding AddSubtaskCommand}"
                                    BackgroundColor="Transparent" TextColor="{StaticResource AccentPurple}" 
                                    FontSize="18" Padding="0" HeightRequest="30" WidthRequest="30" />

                            <!-- Progress Bar -->
                            <VerticalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Progress" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                    <Label Grid.Column="1" Text="{Binding ProgressPercent, StringFormat='{0:F0}%'}" FontSize="11" FontAttributes="Bold" />
                                </Grid>
                                <ProgressBar Progress="{Binding ProgressPercent, Converter={StaticResource PercentToProgressConverter}}" 
                                             ProgressColor="{StaticResource AccentPurple}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                    <Label Text="No goals set for this week yet." HorizontalTextAlignment="Center" />
                    <Button Text="+ Add Goal" Command="{Binding AddGoalCommand}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Actions -->
        <Button Grid.Row="2" Text="+ Add New Goal" Command="{Binding AddGoalCommand}"
                BackgroundColor="{StaticResource AccentPurple}" TextColor="White" 
                FontAttributes="Bold" CornerRadius="12" HeightRequest="48" Margin="0,16,0,0" />

        <!-- Habit Commitments Section -->
        <VerticalStackLayout Grid.Row="1" Spacing="12" Margin="0,24,0,0">
            <Label Text="✅ Habit Commitments" Style="{StaticResource H2}" />
            <Label Text="Small daily wins lead to big results." 
                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" 
                   FontSize="12" Margin="0,-8,0,0" />
            
            <CollectionView ItemsSource="{Binding Habits}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:HabitCommitmentViewModel">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Title}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding TargetFrequency, StringFormat='Target: {0}x'}" FontSize="11" VerticalOptions="Center" />
                                
                                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2" Margin="0,8,0,0">
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="M" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day0Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="0" Scale="0.8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="T" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day1Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="1" Scale="0.8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="W" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day2Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="2" Scale="0.8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="T" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day3Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="3" Scale="0.8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="F" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day4Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="4" Scale="0.8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="S" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day5Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="5" Scale="0.8" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="S" FontSize="9" HorizontalOptions="Center" />
                                        <CheckBox IsChecked="{Binding Day6Checked, Mode=OneWay}" 
                                                  Command="{Binding ToggleDayCommand}" CommandParameter="6" Scale="0.8" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Button Text="+ Add Habit Commitment" Command="{Binding AddHabitCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource AccentPurple}" BorderWidth="1" BorderColor="{StaticResource AccentPurple}" />
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Weekly Reflection Section -->
        <VerticalStackLayout Grid.Row="1" Spacing="12" Margin="0,24,0,32">
            <Label Text="💭 Weekly Reflection" Style="{StaticResource H2}" />
            <Label Text="Reflect on your progress to grow faster." 
                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" 
                   FontSize="12" Margin="0,-8,0,0" />

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Wins of the week" FontAttributes="Bold" FontSize="13" />
                        <Editor Text="{Binding Reflection.Wins}" 
                                Placeholder="What went well?" 
                                AutoSize="TextChanges" HeightRequest="80" 
                                BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Improvements for next week" FontAttributes="Bold" FontSize="13" />
                        <Editor Text="{Binding Reflection.Improvements}" 
                                Placeholder="What could be better?" 
                                AutoSize="TextChanges" HeightRequest="80" 
                                BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto">
                        <Label Text="Weekly Score (1-10)" VerticalOptions="Center" FontAttributes="Bold" FontSize="13" />
                        <Entry Grid.Column="1" Text="{Binding Reflection.WeeklyScore}" 
                               Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" />
                    </Grid>

                    <Button Text="Save Reflection" Command="{Binding SaveReflectionCommand}"
                            BackgroundColor="{StaticResource AccentPurple}" TextColor="White" 
                            CornerRadius="8" HeightRequest="40" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
