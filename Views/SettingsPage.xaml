<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeeklyTimetable.Views.SettingsPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Spacing="8" Padding="16">

            <!-- Appearance -->
            <Label Text="Appearance" Style="{StaticResource MonoLabel}" Margin="0,12,0,4" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Theme" VerticalOptions="Center" />
                        <Picker Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" TextColor="{StaticResource AccentPurple}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Font Size" VerticalOptions="Center" />
                        <Picker Grid.Column="1" ItemsSource="{Binding FontSizes}" SelectedItem="{Binding SelectedFontSize}" TextColor="{StaticResource AccentPurple}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Timeline Editor -->
            <Label Text="Timeline Master Editor" Style="{StaticResource MonoLabel}" Margin="0,12,0,4" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Select Day" VerticalOptions="Center" />
                        <Picker Grid.Column="1" ItemsSource="{Binding DaysOfWeek}" SelectedItem="{Binding SelectedDay}" TextColor="{StaticResource AccentPurple}" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding DayBlocks}" HeightRequest="400">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0, 4" Padding="0, 8">
                                    <Label Grid.Column="0" Text="{Binding Icon}" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0"/>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding Label}" FontAttributes="Bold" FontSize="14" />
                                        <Label Text="{Binding Category}" Style="{StaticResource MonoLabel}" Margin="0,2,0,0" 
                                           TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                    </VerticalStackLayout>
                                    <TimePicker Grid.Column="2" Time="{Binding TimeValue}" TextColor="{StaticResource AccentPurple}" Format="h:mm tt" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Notifications -->
            <Label Text="Notifications" Style="{StaticResource MonoLabel}" Margin="0,12,0,4" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Enable Notifications" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding NotificationsEnabled}" OnColor="{StaticResource AccentPurple}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Haptic Feedback" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding HapticEnabled}" OnColor="{StaticResource AccentPurple}" />
                    </Grid>
                    <BoxView Color="{AppThemeBinding Light={StaticResource BorderLightLight}, Dark={StaticResource BorderLightDark}}" HeightRequest="1" Opacity="0.5" />
                    <!-- Alarm Sound Picker -->
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="Alarm Sound" VerticalOptions="Center" />
                            <Label Text="Sound played when a block starts"
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                   FontSize="11" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="{Binding SelectedAlarmSoundName}"
                                Command="{Binding PickAlarmSoundCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource AccentPurple}"
                                BorderColor="{StaticResource AccentPurple}"
                                BorderWidth="1"
                                CornerRadius="8"
                                FontSize="12"
                                HeightRequest="36"
                                Padding="12,0"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Cloud Backup (Supabase) -->
            <Label Text="Cloud Backup" Style="{StaticResource MonoLabel}" Margin="0,12,0,4" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Entry Placeholder="Email" Text="{Binding SupabaseEmail}" Keyboard="Email" TextColor="{StaticResource TextHeading}" />
                    <Entry Placeholder="Password" Text="{Binding SupabasePassword}" IsPassword="True" TextColor="{StaticResource TextHeading}" />
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="☁️ Backup" Command="{Binding BackupCommand}" BackgroundColor="{StaticResource AccentPurple}" TextColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}" CornerRadius="8" />
                        <Button Text="📥 Restore" Command="{Binding RestoreCommand}" BackgroundColor="Transparent" TextColor="{StaticResource SuccessGreen}" BorderColor="{StaticResource SuccessGreen}" BorderWidth="1" CornerRadius="8" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding SupabaseStatusMessage}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Data -->
            <Label Text="Data Management" Style="{StaticResource MonoLabel}" Margin="0,12,0,4" />
            <Border Style="{StaticResource CardStyle}">
                <Button Text="Reset All Data" Command="{Binding ResetAllDataCommand}"
                        BackgroundColor="Transparent" TextColor="#ef4444"
                        BorderColor="#ef4444" BorderWidth="1" CornerRadius="8" />
            </Border>

            <!-- About -->
            <Label Text="About" Style="{StaticResource MonoLabel}" Margin="0,12,0,4" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Weekly Blueprint — Track &amp; Thrive" FontAttributes="Bold" />
                    <Label Text="Version 2.0 · .NET 10 MAUI" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
